             add_to_variable = { jzm_paixi = 15 }
             add_to_variable = { hjt_paixi =  -15}
		CPC_zhengquan_clamper = yes
		CPC_zhengquan_effect = yes
		add_power_balance_value = {
           id = PRC_power_balance
           value = 0.15
           tooltip_side = PRC_Shanghai_clique_side
        }
	}
}
