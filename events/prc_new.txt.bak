country_event = {
	id = prc_zz.11
	title = prc_zz.11.t
	desc = prc_zz.11.d
	is_triggered_only = yes
	hidden = yes

	option = {
		name = prc_zz.11.a
		ai_chance = {
		        factor = 100
	    }
		 if = {
			limit = {
				check_variable = { jzm_paixi > hjt_paixi }
			}
			country_event = {
				id = prc_zz.12
				days = 1
		    }
		 }
		else_if = {
			limit = {
				check_variable = { hjt_paixi > jzm_paixi }
			}
			country_event = {
				id = prc_zz.13
				days = 1
		    }
		}
    }
}
country_event = {
	id = prc_zz.12
	title = prc_zz.11.t
	desc = prc_zz.12.d
	picture = GFX_report_event_16th_3rd_wu
