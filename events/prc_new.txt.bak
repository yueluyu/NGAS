country_event = {
	id = prc_zz.1
	title = prc_zz.1.t
	desc = prc_zz.1.d
	picture = GFX_report_event_sixteenth_prc
	fire_only_once = yes
	is_triggered_only = yes
	
	immediate = {
	  hidden_effect = {
		load_focus_tree = aaa_PRC_Focus_2
		mark_focus_tree_layout_dirty = yes
		complete_national_focus = { focus = PRC_the_16th_national_congress }
	 }
	}

	option = {
		name = prc_zz.1.a
		hidden_effect = {
		    country_event = {
				id = prc_zz.2
				days = 6
			}
		}
		set_country_flag = 16th_begin_prc
		
	}
}

