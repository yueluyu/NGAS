		custom_effect_tooltip = zeng_huan_wen
		hidden_effect  = {
		remove_ideas = Zhu_is_zongli
		remove_ideas = Wen_is_zongli
		add_ideas = Zeng_is_zongli
	    remove_ideas = PRC_wen_jiabao
	    remove_ideas = PRC_zhu_longji
		add_ideas = PRC_zeng_qinghong
		set_country_flag = COUNTRY_HAS_SECONDARY_LEADER 
	    }
		set_country_flag = jiang_pai_temporary_victory
