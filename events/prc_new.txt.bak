country_event = {
	id = prc_sars.6
	title = prc_sars.6
	desc = prc_sars.6.d
	picture = GFX_19205940
	fire_only_once = yes
	is_triggered_only = yes

	option = {
		name = prc_sars.6.a
		if = {
				limit = {
					has_idea = PRC_SRAS_3
				}
				swap_ideas = {
					remove_idea = PRC_SRAS_3
					add_idea = PRC_SRAS_4
				}
			}
			else_if = {
				limit = {
					has_idea = PRC_SRAS_4
				}
				swap_ideas = {
					remove_idea = PRC_SRAS_4
					add_idea = PRC_SRAS_5
				}
			}
	    }
}


